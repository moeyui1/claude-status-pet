{
  "productName": "claude-status-pet",
  "version": "0.10.0",
  "identifier": "com.claude.status-pet",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
