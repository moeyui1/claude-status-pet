        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "COPILOT_HOOK_EVENT=postToolUse ~/.claude/pet-data/bin/claude-status-pet write-status --adapter copilot",
        "powershell": "$env:COPILOT_HOOK_EVENT='postToolUse'; & \"$env:USERPROFILE\\.claude\\pet-data\\bin\\claude-status-pet-windows-x64.exe\" write-status --adapter copilot",
        "timeoutSec": 10
