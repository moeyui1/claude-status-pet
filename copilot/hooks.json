{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "COPILOT_HOOK_EVENT=sessionStart ~/.claude/pet-data/bin/claude-status-pet write-status --adapter copilot",
        "powershell": "$env:COPILOT_HOOK_EVENT='sessionStart'; & \"$env:USERPROFILE\\.claude\\pet-data\\bin\\claude-status-pet-windows-x64.exe\" write-status --adapter copilot",
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "COPILOT_HOOK_EVENT=sessionEnd ~/.claude/pet-data/bin/claude-status-pet write-status --adapter copilot",
        "powershell": "$env:COPILOT_HOOK_EVENT='sessionEnd'; & \"$env:USERPROFILE\\.claude\\pet-data\\bin\\claude-status-pet-windows-x64.exe\" write-status --adapter copilot",
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "COPILOT_HOOK_EVENT=userPromptSubmitted ~/.claude/pet-data/bin/claude-status-pet write-status --adapter copilot",
        "powershell": "$env:COPILOT_HOOK_EVENT='userPromptSubmitted'; & \"$env:USERPROFILE\\.claude\\pet-data\\bin\\claude-status-pet-windows-x64.exe\" write-status --adapter copilot",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "COPILOT_HOOK_EVENT=preToolUse ~/.claude/pet-data/bin/claude-status-pet write-status --adapter copilot",
