{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "bash ~/.claude/pet-data/scripts/copilot-hook.sh sessionStart",
        "powershell": "& \"$env:USERPROFILE\\.claude\\pet-data\\scripts\\copilot-hook.ps1\" sessionStart",
        "timeoutSec": 1
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "bash ~/.claude/pet-data/scripts/copilot-hook.sh sessionEnd",
        "powershell": "& \"$env:USERPROFILE\\.claude\\pet-data\\scripts\\copilot-hook.ps1\" sessionEnd",
        "timeoutSec": 1
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "bash ~/.claude/pet-data/scripts/copilot-hook.sh userPromptSubmitted",
        "powershell": "& \"$env:USERPROFILE\\.claude\\pet-data\\scripts\\copilot-hook.ps1\" userPromptSubmitted",
        "timeoutSec": 1
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "bash ~/.claude/pet-data/scripts/copilot-hook.sh preToolUse",
        "powershell": "& \"$env:USERPROFILE\\.claude\\pet-data\\scripts\\copilot-hook.ps1\" preToolUse",
        "timeoutSec": 1
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "bash ~/.claude/pet-data/scripts/copilot-hook.sh postToolUse",
        "powershell": "& \"$env:USERPROFILE\\.claude\\pet-data\\scripts\\copilot-hook.ps1\" postToolUse",
        "timeoutSec": 1
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": "bash ~/.claude/pet-data/scripts/copilot-hook.sh errorOccurred",
        "powershell": "& \"$env:USERPROFILE\\.claude\\pet-data\\scripts\\copilot-hook.ps1\" errorOccurred",
        "timeoutSec": 1
      }
    ],
    "stop": [
      {
        "type": "command",
        "bash": "bash ~/.claude/pet-data/scripts/copilot-hook.sh stop",
        "powershell": "& \"$env:USERPROFILE\\.claude\\pet-data\\scripts\\copilot-hook.ps1\" stop",
        "timeoutSec": 1
      }
    ]
  }
}

