{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "COPILOT_HOOK_EVENT=sessionStart bash ~/.claude/pet-data/scripts/copilot-status-writer.sh",
        "powershell": "$env:COPILOT_HOOK_EVENT='sessionStart'; node \"$env:USERPROFILE\\.claude\\pet-data\\scripts\\copilot-status-writer.js\"",
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "COPILOT_HOOK_EVENT=sessionEnd bash ~/.claude/pet-data/scripts/copilot-status-writer.sh",
        "powershell": "$env:COPILOT_HOOK_EVENT='sessionEnd'; node \"$env:USERPROFILE\\.claude\\pet-data\\scripts\\copilot-status-writer.js\"",
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "COPILOT_HOOK_EVENT=userPromptSubmitted bash ~/.claude/pet-data/scripts/copilot-status-writer.sh",
        "powershell": "$env:COPILOT_HOOK_EVENT='userPromptSubmitted'; node \"$env:USERPROFILE\\.claude\\pet-data\\scripts\\copilot-status-writer.js\"",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "COPILOT_HOOK_EVENT=preToolUse bash ~/.claude/pet-data/scripts/copilot-status-writer.sh",
        "powershell": "$env:COPILOT_HOOK_EVENT='preToolUse'; node \"$env:USERPROFILE\\.claude\\pet-data\\scripts\\copilot-status-writer.js\"",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "COPILOT_HOOK_EVENT=postToolUse bash ~/.claude/pet-data/scripts/copilot-status-writer.sh",
        "powershell": "$env:COPILOT_HOOK_EVENT='postToolUse'; node \"$env:USERPROFILE\\.claude\\pet-data\\scripts\\copilot-status-writer.js\"",
        "timeoutSec": 10
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": "COPILOT_HOOK_EVENT=errorOccurred bash ~/.claude/pet-data/scripts/copilot-status-writer.sh",
        "powershell": "$env:COPILOT_HOOK_EVENT='errorOccurred'; node \"$env:USERPROFILE\\.claude\\pet-data\\scripts\\copilot-status-writer.js\"",
        "timeoutSec": 10
      }
    ]
  }
}
