    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": "COPILOT_HOOK_EVENT=errorOccurred ~/.claude/pet-data/bin/claude-status-pet write-status --adapter copilot",
        "powershell": "$env:COPILOT_HOOK_EVENT='errorOccurred'; & \"$env:USERPROFILE\\.claude\\pet-data\\bin\\claude-status-pet-windows-x64.exe\" write-status --adapter copilot",
        "timeoutSec": 10
      }
    ],
    "stop": [
      {
        "type": "command",
        "bash": "COPILOT_HOOK_EVENT=stop ~/.claude/pet-data/bin/claude-status-pet write-status --adapter copilot",
        "powershell": "$env:COPILOT_HOOK_EVENT='stop'; & \"$env:USERPROFILE\\.claude\\pet-data\\bin\\claude-status-pet-windows-x64.exe\" write-status --adapter copilot",
        "timeoutSec": 10
      }
    ]
  }
}
