{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "command": "~/.claude/pet-data/bin/claude-status-pet write-status --adapter copilot",
        "windows": "$env:USERPROFILE\\.claude\\pet-data\\bin\\claude-status-pet-windows-x64.exe write-status --adapter copilot",
        "timeoutSec": 5
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "command": "~/.claude/pet-data/bin/claude-status-pet write-status --adapter copilot",
        "windows": "$env:USERPROFILE\\.claude\\pet-data\\bin\\claude-status-pet-windows-x64.exe write-status --adapter copilot",
        "timeoutSec": 5
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "command": "~/.claude/pet-data/bin/claude-status-pet write-status --adapter copilot",
        "windows": "$env:USERPROFILE\\.claude\\pet-data\\bin\\claude-status-pet-windows-x64.exe write-status --adapter copilot",
        "timeoutSec": 5
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "command": "~/.claude/pet-data/bin/claude-status-pet write-status --adapter copilot",
        "windows": "$env:USERPROFILE\\.claude\\pet-data\\bin\\claude-status-pet-windows-x64.exe write-status --adapter copilot",
        "timeoutSec": 5
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "command": "~/.claude/pet-data/bin/claude-status-pet write-status --adapter copilot",
        "windows": "$env:USERPROFILE\\.claude\\pet-data\\bin\\claude-status-pet-windows-x64.exe write-status --adapter copilot",
        "timeoutSec": 5
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "command": "~/.claude/pet-data/bin/claude-status-pet write-status --adapter copilot",
        "windows": "$env:USERPROFILE\\.claude\\pet-data\\bin\\claude-status-pet-windows-x64.exe write-status --adapter copilot",
        "timeoutSec": 5
      }
    ],
    "stop": [
      {
        "type": "command",
        "command": "~/.claude/pet-data/bin/claude-status-pet write-status --adapter copilot",
        "windows": "$env:USERPROFILE\\.claude\\pet-data\\bin\\claude-status-pet-windows-x64.exe write-status --adapter copilot",
        "timeoutSec": 5
      }
    ]
  }
}
