    { "path": "gopher/with-C-book.svg",     "url": "https://raw.githubusercontent.com/egonelbre/gophers/master/vector/projects/with-C-book.svg" },
    { "path": "gopher/vim-go.svg",          "url": "https://raw.githubusercontent.com/egonelbre/gophers/master/vector/projects/vim-go.svg" },
    { "path": "gopher/hiking.svg",          "url": "https://raw.githubusercontent.com/egonelbre/gophers/master/vector/adventure/hiking.svg" },
    { "path": "gopher/jet-pack.svg",        "url": "https://raw.githubusercontent.com/egonelbre/gophers/master/vector/science/jet-pack.svg" },
    { "path": "gopher/standing.svg",        "url": "https://raw.githubusercontent.com/egonelbre/gophers/master/vector/superhero/standing.svg" },
    { "path": "gopher/heart-balloon.svg",   "url": "https://raw.githubusercontent.com/egonelbre/gophers/master/vector/friends/heart-balloon.svg" },
    { "path": "gopher/mistake.svg",         "url": "https://raw.githubusercontent.com/egonelbre/gophers/master/vector/science/mistake.svg" },
    { "path": "gopher/music.svg",           "url": "https://raw.githubusercontent.com/egonelbre/gophers/master/vector/party/music.svg" },
