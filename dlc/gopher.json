    { "path": "gopher/knight.svg",          "url": "https://raw.githubusercontent.com/egonelbre/gophers/master/vector/fairy-tale/knight.svg" }
  ],
  "states": {
    "idle":       ["gopher/sage.svg", "gopher/music.svg"],
    "thinking":   ["gopher/witch-learning.svg", "gopher/scientist.svg"],
    "reading":    ["gopher/with-C-book.svg"],
    "editing":    ["gopher/vim-go.svg"],
    "searching":  ["gopher/hiking.svg"],
    "running":    ["gopher/jet-pack.svg", "gopher/knight.svg"],
